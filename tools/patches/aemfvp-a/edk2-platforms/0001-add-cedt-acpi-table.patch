Date: Wed, 11 Feb 2026 07:32:16 +0000
Subject: [PATCH] add cedt acpi table

Signed-off-by: Shyamanth RH <shyamanth.rh@arm.com>
---
 .../AslTables/Dsdt.asl                        | 26 +++++--
 .../ConfigurationManagerDxe/Cedt.c            | 77 +++++++++++++++++++
 .../ConfigurationManager.c                    | 31 +++++---
 .../ConfigurationManager.h                    | 11 ++-
 .../ConfigurationManagerDxe.inf               |  7 +-
 5 files changed, 125 insertions(+), 27 deletions(-)
 create mode 100644 Platform/ARM/VExpressPkg/ConfigurationManager/ConfigurationManagerDxe/Cedt.c

diff --git a/Platform/ARM/VExpressPkg/ConfigurationManager/ConfigurationManagerDxe/AslTables/Dsdt.asl b/Platform/ARM/VExpressPkg/ConfigurationManager/ConfigurationManagerDxe/AslTables/Dsdt.asl
index 5df8f5cf7d..65166f8fc2 100644
--- a/Platform/ARM/VExpressPkg/ConfigurationManager/ConfigurationManagerDxe/AslTables/Dsdt.asl
+++ b/Platform/ARM/VExpressPkg/ConfigurationManager/ConfigurationManagerDxe/AslTables/Dsdt.asl
@@ -14,9 +14,9 @@ DefinitionBlock("DsdtTable.aml", "DSDT", 2, "ARMLTD", "ARM-VEXP", 1) {
     //
     // Processor declaration
     //
-    Method (_OSC, 4, Serialized)  { // _OSC: Operating System Capabilities
-      CreateDWordField (Arg3, 0x00, STS0)
-      CreateDWordField (Arg3, 0x04, CAP0)
+    Method (_OSC, 4, Serialized)  { // _OSC: Operating System Capabilities
+      CreateDWordField (Arg3, 0x00, STS0)
+      CreateDWordField (Arg3, 0x04, CAP0)
       If ((Arg0 == ToUUID ("0811b06e-4a27-44f9-8d60-3cbbc22e7b48") /* Platform-wide Capabilities */)) {
         If (!(Arg1 == One)) {
           STS0 &= ~0x1F
@@ -32,11 +32,21 @@ DefinitionBlock("DsdtTable.aml", "DSDT", 2, "ARMLTD", "ARM-VEXP", 1) {
         STS0 &= ~0x1F
         STS0 |= 0x06
       }
-      Return (Arg3)
-    }
-
-    // SMC91X
-    Device (NET0) {
+      Return (Arg3)
+    }
+
+    // PCI Root Bridge
+    Device (PCI0) {
+      Name (_HID, "PNP0A08") // PCI Express Root Bridge
+      Name (_CID, "PNP0A03") // Compatible PCI Root Bridge
+      Name (_UID, 0)
+      Name (_SEG, 0)
+      Name (_BBN, 0)
+      Name (_CCA, 1)
+    }
+
+    // SMC91X
+    Device (NET0) {
       Name (_HID, "LNRO0003")
       Name (_UID, 0)
 
diff --git a/Platform/ARM/VExpressPkg/ConfigurationManager/ConfigurationManagerDxe/Cedt.c b/Platform/ARM/VExpressPkg/ConfigurationManager/ConfigurationManagerDxe/Cedt.c
new file mode 100644
index 0000000000..f067c0ee5b
--- /dev/null
+++ b/Platform/ARM/VExpressPkg/ConfigurationManager/ConfigurationManagerDxe/Cedt.c
@@ -0,0 +1,77 @@
+#include <Base.h>
+#include <IndustryStandard/Acpi64.h>
+
+#define VEXPRESS_ACPI_OEM_ID           { 'A', 'R', 'M', 'L', 'T', 'D' }
+#define VEXPRESS_ACPI_OEM_TABLE_ID     SIGNATURE_64 ('V', 'E', 'X', 'P', 'R', 'E', 'S', 'S')
+#define VEXPRESS_ACPI_OEM_REVISION     0x20140727
+#define VEXPRESS_ACPI_CREATOR_ID       SIGNATURE_32 ('A', 'R', 'M', ' ')
+#define VEXPRESS_ACPI_CREATOR_REVISION 0x00000099
+
+#define VEXPRESS_CEDT_INTERLEAVE_TARGETS  1
+
+#pragma pack (1)
+
+typedef struct {
+  UINT8   Type;
+  UINT8   Reserved0;
+  UINT16  RecordLength;
+  UINT32  Reserved1;
+  UINT64  BaseHpa;
+  UINT64  WindowSize;
+  UINT8   EncodedNumberOfInterleaveWays;
+  UINT8   InterleaveArithmetic;
+  UINT16  Reserved2;
+  UINT32  HostBridgeInterleaveGranularity;
+  UINT16  WindowRestrictions;
+  UINT16  QtgId;
+  UINT32  InterleaveTargetList[VEXPRESS_CEDT_INTERLEAVE_TARGETS];
+} VEXPRESS_CEDT_CFMWS_STRUCTURE;
+
+typedef struct {
+  EFI_ACPI_DESCRIPTION_HEADER                 Header;
+  VEXPRESS_CEDT_CFMWS_STRUCTURE               Cfmws;
+  EFI_ACPI_6_4_CEDT_CXL_HOST_BRIDGE_STRUCTURE  Chbs;
+} VEXPRESS_CEDT_STRUCTURE_TABLE;
+
+#pragma pack ()
+
+VEXPRESS_CEDT_STRUCTURE_TABLE  Cedt = {
+  {
+    EFI_ACPI_6_4_CXL_EARLY_DISCOVERY_TABLE_SIGNATURE,
+    sizeof (VEXPRESS_CEDT_STRUCTURE_TABLE),
+    EFI_ACPI_6_4_CEDT_CXL_EARLY_DISCOVERY_TABLE_REVISION_01,
+    0,
+    VEXPRESS_ACPI_OEM_ID,
+    VEXPRESS_ACPI_OEM_TABLE_ID,
+    VEXPRESS_ACPI_OEM_REVISION,
+    VEXPRESS_ACPI_CREATOR_ID,
+    VEXPRESS_ACPI_CREATOR_REVISION
+  },
+  {
+    EFI_ACPI_6_4_CEDT_STRUCTURE_TYPE_CXL_FIXED_MEMORY_WINDOW_STRUCTURE,
+    EFI_ACPI_RESERVED_BYTE,
+    sizeof (VEXPRESS_CEDT_CFMWS_STRUCTURE),
+    EFI_ACPI_RESERVED_DWORD,
+    0x8C0000000ULL,
+    0x20000000ULL,
+    0,
+    0,
+    EFI_ACPI_RESERVED_WORD,
+    4,
+    6,
+    0,
+    {
+      0
+    }
+  },
+  {
+    EFI_ACPI_6_4_CEDT_STRUCTURE_TYPE_CXL_HOST_BRIDGE_STRUCTURE,
+    EFI_ACPI_RESERVED_BYTE,
+    sizeof (EFI_ACPI_6_4_CEDT_CXL_HOST_BRIDGE_STRUCTURE),
+    0,
+    EFI_ACPI_6_4_CEDT_CXL_HOST_BRIDGE_STRUCTURE_CXL_VERSION_HB,
+    EFI_ACPI_RESERVED_DWORD,
+    0x66E000000ULL,
+    0x10000
+  }
+};
